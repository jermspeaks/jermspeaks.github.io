---
import { getCollection, getEntry, render } from "astro:content";
import CollectionDetailsPage from "../../../layouts/CollectionDetailsPage.astro";
import LogPost from "../../../layouts/LogPost.astro";
import type { CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("log");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}
type Props = CollectionEntry<"log">;

const post = Astro.props;
let previousEntry: Props | null = null;
let nextEntry: Props | null = null;

function entryId(ref: string | { collection: string; id: string } | undefined): string | undefined {
  if (ref == null) return undefined;
  return typeof ref === "string" ? ref : ref.id;
}

const prevId = entryId(post.data.previousEntry);
const nextId = entryId(post.data.nextEntry);
if (prevId) {
  previousEntry = await getEntry("log", prevId) ?? null;
}
if (nextId) {
  nextEntry = await getEntry("log", nextId) ?? null;
}

const { Content } = await render(post);
---

<CollectionDetailsPage
  description={post.data.blurb}
  image={post.data.heroImage}
  imageAlt={post.data.heroImageAlt}
  section="Logs By Year"
  sectionSlug="log"
  title={post.data.title}
>
  <LogPost {...post.data}>
    <!-- <h1>{post.data.title}</h1> -->
    <Content />
    <div class="flex justify-between">
      {
        previousEntry && (
          <a href={`/curation/log/${previousEntry.id}`}>
            ⬅️ Previous: {previousEntry.data.title}
          </a>
        )
      }
      {
        nextEntry && (
          <a href={`/curation/log/${nextEntry.id}`}>Next: {nextEntry.data.title} ➡️</a>
        )
      }
    </div>
  </LogPost>
</CollectionDetailsPage>
