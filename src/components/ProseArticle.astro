---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"article">;

const { class: className } = Astro.props;
const cn = typeof className === "string" ? className : "";
const useLg = !cn.includes("prose--base");
---

<article
  class:list={[
    "prose",
    { "prose--lg": useLg },
    { "max-w-xl md:max-w-2xl mx-auto": !cn.includes("mx-0") },
    className,
  ]}
>
  <slot />
</article>
<style lang="css" is:global>
  h2:hover .heading-link,
  h3:hover .heading-link,
  h4:hover .heading-link,
  h5:hover .heading-link {
    @apply opacity-100;
  }
  .heading-link {
    @apply hidden relative;
  }
  .heading-link svg {
    @apply absolute top-1/2 -translate-y-1/2;
  }

  .external-link {
    @apply inline-block align-super;
  }
</style>
